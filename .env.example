# ============================================================
# Variables d'environnement — Vite & Gourmand
# Copier en .env (jamais commité) pour le développement local
# En production : injecter via Railway / fly.io / Heroku
# ============================================================

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=vite_et_gourmand
DB_USER=root
DB_PASS=

# MongoDB Atlas (remplacer <user>, <pass>, <cluster>)
MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGO_DB=vite_et_gourmand_stats
MONGO_COLL=commandes_stats

# Application
APP_ENV=production
APP_URL=https://votre-app.up.railway.app